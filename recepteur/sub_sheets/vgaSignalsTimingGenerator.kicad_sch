	)
	(text_box "bits de déclenchements :\n(decoding is chained so previous bits doesn't need to be re-evaluated)\nH :\n|->  800 : 011'0010'0000 -> 9+8+5\n|->  840 : 011'0100'1000 -> 6+3\n|->  968 : 011'0100'1000 -> 7+6+3\n|-> 1056 : 100'0010'1000 -> 10+5\nV :\n|->  600 :  10'0101'1000 -> 9+6+4+3\n|->  601 :  10'0101'1001 -> 0\n|->  605 :  10'0101'1101 -> 2+0\n|->  628 :  10'0111'0100 -> 5+4+2\n"
		(exclude_from_sim no)
		(at -102.87 10.16 0)
		(size 101.6 101.6)
		(margins 0.9525 0.9525 0.9525 0.9525)
