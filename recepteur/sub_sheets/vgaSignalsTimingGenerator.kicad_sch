	(text "Timings :\n	Horizontalement (en cycle):\n		800	zone visible.\n		40 	front porch.\n		128	H sync pulse.\n		88 	Back proch.\n	Verticalement (en line horizontales) :\n		600 zone visible.\n		1 	front proch.\n		4	V sync pulse.\n		23	back porch.\n"
		(exclude_from_sim no)
		(at 12.7 12.7 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "950b9eb8-dcc5-4671-a99f-07a7228f3c17")
	)
