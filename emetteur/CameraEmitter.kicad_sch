	(text "C_{L} = 10pF C de charge (Load) du cristal.\nC_{S} = 0.5∼1pF  C parasite (Stray) du PCB.\nC_{L} = C_{1} * C_{2}  +C_{S}\n      ~{C_{1} + C_{2}}\nAvec C_{1} = C_{2}\nC_{1} = C_{2} = 2(C_{L} - C_{S}) = 18∼19pF ≃ 20pF"
		(exclude_from_sim no)
		(at 13.97 128.27 0)
		(effects
			(font
				(size 0.9525 0.9525)
				(italic yes)
			)
			(justify left top)
		)
		(uuid "8d9b6508-d5e4-4432-9368-7a33574c6250")
	)
